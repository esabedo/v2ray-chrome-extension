{
  "name": "v2ray-extension",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "agent:build:go": "node ./scripts/build-go-agent.mjs",
    "agent:run": "./scripts/run-agent-local.sh",
    "build": "npm run clean && tsc -p tsconfig.json && node scripts/copy-static.mjs",
    "clean": "rm -rf dist",
    "package:macos": "./scripts/package-macos-pkg.sh",
    "package:windows": "powershell -ExecutionPolicy Bypass -File ./scripts/package-windows-msi.ps1",
    "smoke:agent": "node scripts/smoke-agent.mjs",
    "smoke:stack": "node scripts/smoke-stack.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "singbox:install:macos": "./scripts/install-singbox-macos.sh",
    "singbox:install:windows": "powershell -ExecutionPolicy Bypass -File ./scripts/install-singbox-windows.ps1"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.310",
    "@types/node": "^24.6.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
